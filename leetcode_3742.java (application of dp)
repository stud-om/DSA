class Solution {
    public int solve(int i, int j, int[][] grid, int k, int[][][] dp) {
        int m = grid.length;
        int n = grid[0].length;

        
        if (k < 0) {
            return (int)-1e9;
        }

        
        if (i == m || j == n) {
            return (int)-1e9;
        }

       
        if (i == m - 1 && j == n - 1) {
            if (Math.min(grid[i][j], 1) <= k) {
                return grid[i][j];
            } else {
                return (int)-1e9;
            }
        }

        
        if (dp[i][j][k] != -1) {
            return dp[i][j][k];
        }

        int cost = Math.min(grid[i][j], 1);

        int right = grid[i][j] + solve(i, j + 1, grid, k - cost, dp);
        int down  = grid[i][j] + solve(i + 1, j, grid, k - cost, dp);

        return dp[i][j][k] = Math.max(right, down);
    }


    public int maxPathScore(int[][] grid, int k) {
        int m = grid.length;
        int n = grid[0].length;

        int[][][] dp = new int[m][n][k + 1];

       
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                for (int c = 0; c <= k; c++) {
                    dp[i][j][c] = -1;
                }
            }
        }

        int ans = solve(0, 0, grid, k, dp);

        return (ans < 0) ? -1 : ans;
    }
}
